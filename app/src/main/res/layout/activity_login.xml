<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB">

    <View
        android:id="@+id/circleTopLarge"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/circle_decoration"
        android:backgroundTint="#E6E9FF"
        android:translationX="120dp"
        android:translationY="-120dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circleTopMedium"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_decoration"
        android:backgroundTint="#C4B5FD"
        android:alpha="0.3"
        android:translationX="40dp"
        android:translationY="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circleBottomLarge"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/circle_decoration"
        android:backgroundTint="#E6E9FF"
        android:translationX="-120dp"
        android:translationY="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/headerTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardLogin">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            app:cardCornerRadius="48dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="1.5dp"
            app:strokeColor="#E6E9FF">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:src="@drawable/logoapht"
                android:scaleType="fitCenter"
                android:padding="18dp"
                android:contentDescription="Logo APHT" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="APHT"
            android:textColor="#6C63FF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Aglomerasi Pabrik Hasil Tembakau"
            android:textColor="#7B78A8"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Kabupaten Sumenep"
            android:textColor="#6C63FF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="1dp"
        app:strokeColor="#F0F2F9"
        app:layout_constraintTop_toBottomOf="@id/headerTop"
        app:layout_constraintBottom_toTopOf="@id/tvVersion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selamat Datang 👋"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1E1B4B"
                android:gravity="start"
                android:includeFontPadding="false" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Silakan masuk ke akun Anda untuk melanjutkan aktivitas presensi."
                android:textSize="14sp"
                android:textColor="#7B78A8"
                android:gravity="start"
                android:lineSpacingExtra="4dp"
                android:includeFontPadding="false"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Alamat Email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxBackgroundColor="#FAFAFD"
                app:boxStrokeColor="#6C63FF"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="#6C63FF"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="#A5B4FC">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:singleLine="true"
                    android:textColor="#1E1B4B"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Kata Sandi"
                android:layout_marginTop="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxBackgroundColor="#FAFAFD"
                app:boxStrokeColor="#6C63FF"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="#6C63FF"
                app:startIconDrawable="@android:drawable/ic_lock_lock"
                app:startIconTint="#A5B4FC"
                app:endIconMode="password_toggle"
                app:endIconTint="#A5B4FC">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:textColor="#1E1B4B"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="36dp"
                android:text="Masuk Sekarang"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:textColor="#FFFFFF"
                app:backgroundTint="#6C63FF"
                app:cornerRadius="20dp"
                app:elevation="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#A5B4FC"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Akun dibuat oleh admin. Hubungi admin jika belum punya akun."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#9E9CB8"
                    android:gravity="center"
                    android:includeFontPadding="false" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AbsenKu v1.0.0"
        android:textColor="#B0ACD4"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>