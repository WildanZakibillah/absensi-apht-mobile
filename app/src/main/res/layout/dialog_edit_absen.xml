<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvEditAbsenUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama User"
        android:textColor="#2D2B55"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvEditAbsenDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2026-02-10"
        android:textColor="#7B78A8"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvEditAbsenStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: belum absen"
        android:textColor="#6C63FF"
        android:textSize="12sp"
        android:layout_marginBottom="14dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Jam Masuk (HH:mm)"
        android:layout_marginBottom="10dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <EditText
            android:id="@+id/etEditCheckIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:focusable="false"
            android:clickable="true"
            android:textColor="#2D2B55"
            android:hint="Ketuk untuk pilih" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Jam Pulang (HH:mm)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <EditText
            android:id="@+id/etEditCheckOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:focusable="false"
            android:clickable="true"
            android:textColor="#2D2B55"
            android:hint="Ketuk untuk pilih" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>