<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F3FF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════════════════════════════
                 HERO HEADER
                 ════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#6C63FF"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="30dp"
                android:paddingBottom="24dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:id="@+id/dekorCircleLarge"
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:background="@drawable/circle_decoration"
                        android:backgroundTint="#FFFFFF"
                        android:alpha="0.06"
                        android:translationX="60dp"
                        android:translationY="-70dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:id="@+id/dekorCircleSmall"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="@drawable/circle_decoration"
                        android:backgroundTint="#FFFFFF"
                        android:alpha="0.08"
                        android:translationX="-15dp"
                        android:translationY="20dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#7C74FF"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/arrow_back"
                            android:contentDescription="Kembali"
                            app:tint="#FFFFFF" />

                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/headerContent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="20dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="#7C74FF"
                            app:cardElevation="0dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvHeaderEmoji"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="📍"
                                android:textSize="36sp" />

                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvHeaderTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Absen Masuk"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.01" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvHeaderSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Jadwal: 08:00 WIB"
                            android:textColor="#C4B5FD"
                            android:textSize="14sp" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/chipStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:cardCornerRadius="20dp"
                            app:cardBackgroundColor="#E8FBF4"
                            app:cardElevation="0dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvChipStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="6dp"
                                android:paddingBottom="6dp"
                                android:text="✓  Tepat Waktu"
                                android:textColor="#4ECCA3"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Card Jam & Tanggal -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="10dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="24dp"
                        android:paddingBottom="24dp"
                        android:gravity="center">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvCurrentTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00 : 00 : 00"
                            android:textColor="#2D2B55"
                            android:textSize="44sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.03" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvCurrentDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Senin, 10 Februari 2026"
                            android:textColor="#7B78A8"
                            android:textSize="13sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>


            <!-- ════════════════════════════════
                 AREA KONTEN
                 ════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="40dp"
                android:paddingTop="12dp">


                <!-- ════════════════════════════════
                     CARD: TOGGLE MODE IZIN
                     Card ini selalu tampil di atas
                     ════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardIzinMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#E9D5FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <!-- Ikon Izin -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#F3E8FF"
                            app:cardElevation="0dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="📋"
                                android:textSize="20sp" />

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Teks Izin -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ajukan Izin"
                                android:textColor="#2D2B55"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Sakit, keperluan, dinas luar, dll."
                                android:textColor="#7B78A8"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <!-- Badge / Switch -->
                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvIzinBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:text="✓ Aktif"
                            android:textColor="#9333EA"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_chip_purple"
                            android:visibility="gone" />

                        <!-- Arrow icon -->
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="8dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="Toggle izin"
                            app:tint="#C4B5FD" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- ════════════════════════════════
                     CARD: DETAIL IZIN
                     (Tampil hanya saat mode izin aktif)
                     ════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layoutIzinDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FEFCE8"
                        app:strokeColor="#FDE68A"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <!-- Header -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="14dp">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    app:cardCornerRadius="10dp"
                                    app:cardBackgroundColor="#FEF3C7"
                                    app:cardElevation="0dp">

                                    <com.google.android.material.textview.MaterialTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:text="📝"
                                        android:textSize="16sp" />

                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="12dp"
                                    android:text="Jenis Izin"
                                    android:textColor="#92400E"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="wajib dipilih"
                                    android:textColor="#D97706"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <!-- Radio Group Tipe Izin -->
                            <RadioGroup
                                android:id="@+id/rgIzinType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <RadioButton
                                    android:id="@+id/rbSakit"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:text="🤒  Sakit"
                                    android:textColor="#2D2B55"
                                    android:textSize="14sp"
                                    android:buttonTint="#6C63FF"
                                    android:paddingStart="8dp" />

                                <RadioButton
                                    android:id="@+id/rbKeperluan"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:text="🏡  Keperluan Pribadi"
                                    android:textColor="#2D2B55"
                                    android:textSize="14sp"
                                    android:buttonTint="#6C63FF"
                                    android:paddingStart="8dp" />

                                <RadioButton
                                    android:id="@+id/rbDinas"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:text="💼  Dinas Luar"
                                    android:textColor="#2D2B55"
                                    android:textSize="14sp"
                                    android:buttonTint="#6C63FF"
                                    android:paddingStart="8dp" />

                                <RadioButton
                                    android:id="@+id/rbCuti"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:text="🏖️  Cuti"
                                    android:textColor="#2D2B55"
                                    android:textSize="14sp"
                                    android:buttonTint="#6C63FF"
                                    android:paddingStart="8dp" />

                                <RadioButton
                                    android:id="@+id/rbLainnya"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:text="📌  Lainnya"
                                    android:textColor="#2D2B55"
                                    android:textSize="14sp"
                                    android:buttonTint="#6C63FF"
                                    android:paddingStart="8dp" />

                            </RadioGroup>

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="12dp"
                                android:background="#FDE68A" />

                            <!-- Field Alasan -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilIzinAlasan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Alasan izin (opsional)..."
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxBackgroundColor="#FFFBEB"
                                app:boxStrokeColor="#FCD34D"
                                app:hintTextColor="#D97706">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etIzinAlasan"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:minLines="2"
                                    android:maxLines="4"
                                    android:inputType="textMultiLine|textCapSentences"
                                    android:textColor="#2D2B55"
                                    android:textSize="14sp"
                                    android:paddingTop="14dp"
                                    android:paddingBottom="14dp" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Info: Lokasi tetap dicatat -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_info_yellow"
                                android:padding="12dp">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ℹ️"
                                    android:textSize="16sp"
                                    android:layout_marginEnd="8dp" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Lokasi &amp; foto kamu tetap dicatat sebagai bukti. Izin menunggu persetujuan admin."
                                    android:textColor="#92400E"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
                <!-- END layoutIzinDetails -->


                <!-- ════════════════════════
                     CARD: Lokasi GPS
                     ════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="#EEF0FF"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_menu_mylocation"
                                    android:contentDescription="Lokasi"
                                    app:tint="#6C63FF" />

                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Lokasi GPS"
                                android:textColor="#2D2B55"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardGpsStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="20dp"
                                app:cardBackgroundColor="#FFF0F0"
                                app:cardElevation="0dp">

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/tvGpsStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:text="Mendeteksi..."
                                    android:textColor="#EF4444"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvLocationName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mendapatkan lokasi..."
                            android:textColor="#2D2B55"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvLocationCoord"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Lat: —  ·  Lng: —"
                            android:textColor="#7B78A8"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="12dp"
                            android:background="#F0EEFF" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/ic_dialog_info"
                                android:contentDescription="Info"
                                android:layout_marginEnd="7dp"
                                app:tint="#A5B4FC" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvRadiusInfo"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Radius absen: 100 meter dari kantor"
                                android:textColor="#7B78A8"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="Jarak: menghitung..."
                            android:textColor="#6C63FF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progressDistance"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:progress="0"
                            android:max="100"
                            android:progressTint="#6C63FF"
                            android:progressBackgroundTint="#EEF0FF" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- ════════════════════════
                     CARD: Foto Selfie
                     ════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="#EEF0FF"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_menu_camera"
                                    android:contentDescription="Kamera"
                                    app:tint="#6C63FF" />

                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Foto Selfie"
                                android:textColor="#2D2B55"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="20dp"
                                app:cardBackgroundColor="#FFF8E7"
                                app:cardElevation="0dp">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:text="Tersimpan Lokal"
                                    android:textColor="#F59E0B"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardPhotoPreview"
                            android:layout_width="match_parent"
                            android:layout_height="170dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#F4F3FF"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:id="@+id/layoutPhotoPlaceholder"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📷"
                                    android:textSize="38sp" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="Ketuk untuk ambil foto"
                                    android:textColor="#7B78A8"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Foto disimpan di memori HP"
                                    android:textColor="#B0ACD4"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivPhotoPreview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="Preview foto selfie"
                                android:visibility="gone" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnRetakePhoto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|end"
                                android:layout_margin="10dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:visibility="gone"
                                app:cardCornerRadius="20dp"
                                app:cardBackgroundColor="#6C63FF"
                                app:cardElevation="4dp">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:paddingTop="7dp"
                                    android:paddingBottom="7dp"
                                    android:text="🔄  Ganti Foto"
                                    android:textColor="#FFFFFF"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                            </com.google.android.material.card.MaterialCardView>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- ════════════════════════
                     CARD: Catatan
                     ════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="#EEF0FF"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_menu_edit"
                                    android:contentDescription="Catatan"
                                    app:tint="#6C63FF" />

                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Catatan"
                                android:textColor="#2D2B55"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="(opsional)"
                                android:textColor="#B0ACD4"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tambahkan catatan..."
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxBackgroundColor="#F8F7FF"
                            app:boxStrokeColor="#C4B5FD"
                            app:hintTextColor="#A5B4FC">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNotes"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minLines="2"
                                android:maxLines="4"
                                android:inputType="textMultiLine|textCapSentences"
                                android:textColor="#2D2B55"
                                android:textSize="14sp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>


                <!-- ════════════════════════
                     TOMBOL ABSEN / IZIN
                     ════════════════════════ -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAbsen"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="24dp"
                    android:text="Absen Sekarang"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"
                    app:backgroundTint="#6C63FF"
                    app:cornerRadius="16dp"
                    app:elevation="6dp"
                    app:icon="@drawable/ic_check"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="#FFFFFF" />


                <!-- ════════════════════════
                     LOADING INDICATOR
                     ════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layoutLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminateTint="#6C63FF"
                        android:layout_marginEnd="10dp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Menyimpan data absen..."
                        android:textColor="#7B78A8"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>